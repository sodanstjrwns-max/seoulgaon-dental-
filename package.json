{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node -e \"const f=require('fs');const d=JSON.parse(f.readFileSync('dist/_routes.json'));d.exclude=d.exclude.filter(x=>x!=='/sitemap.xml');['aesthetic','resin-buildup','implant'].forEach(p=>{if(!d.exclude.includes('/'+p+'.html'))d.exclude.push('/'+p+'.html')});if(!d.exclude.includes('/llms.txt'))d.exclude.push('/llms.txt');f.writeFileSync('dist/_routes.json',JSON.stringify(d))\"",
    "preview": "wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "hono": "^4.12.10"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}